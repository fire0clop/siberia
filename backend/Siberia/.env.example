# ─── Database (required) ──────────────────────────────────────────────────────
# Async SQLAlchemy URL. Format: postgresql+asyncpg://user:pass@host:5432/db
DATABASE_URL=postgresql+asyncpg://siberia:siberia@localhost:5432/siberia

# ─── Auth (required) ──────────────────────────────────────────────────────────
# Long random string used to sign JWTs (min 32 chars — enforced at startup
# when ENV=production). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=1
REFRESH_TOKEN_EXPIRE_DAYS=30

# Max concurrent device sessions per user (FIFO-evicted beyond this).
MAX_SESSIONS=5

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Environment / CORS ───────────────────────────────────────────────────────
# ENV=production forbids CORS_ORIGINS="*" (the app refuses to start).
ENV=development
DEBUG=false
# Dev: CORS_ORIGINS=*
# Prod: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# ─── Email verification tunables ──────────────────────────────────────────────
VERIFY_CODE_TTL_MINUTES=15
VERIFY_CODE_MAX_ATTEMPTS=5
VERIFY_CODE_LOCKOUT_MINUTES=15

# ─── WebSocket heartbeat ──────────────────────────────────────────────────────
WS_PING_INTERVAL=25
WS_PING_TIMEOUT=10

# ─── APNs (iOS push) ──────────────────────────────────────────────────────────
# Path to the .p8 auth key from Apple Developer → Keys.
APNS_KEY_PATH=
APNS_KEY_ID=          # 10-char Key ID
APNS_TEAM_ID=         # 10-char Team ID
APNS_BUNDLE_ID=       # e.g. com.example.siberia
APNS_SANDBOX=true     # true = sandbox/TestFlight, false = production

# ─── FCM (Android push) ───────────────────────────────────────────────────────
FCM_SERVER_KEY=

# ─── S3-compatible object storage (AWS S3 / Cloudflare R2 / MinIO) ────────────
S3_BUCKET=
S3_ENDPOINT=          # "" = AWS default; https://<account>.r2.cloudflarestorage.com for R2
S3_KEY_ID=
S3_SECRET=
S3_REGION=auto
# Public base URL for presigned links (e.g. http://localhost:9000 for local MinIO).
# If set, its host replaces S3_ENDPOINT's host so mobile clients can reach storage.
S3_PUBLIC_URL=

# ─── SMTP (email verification / security alerts) ──────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=true

# ─── Docker Compose only ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=siberia

# ─── Calls / TURN (client-side config; see backend/deploy/coturn) ─────────────
# The TURN server credentials live in the iOS app's WebRTC ICE config, not here.
# See backend/deploy/coturn/turnserver.conf for the coturn deployment template.
